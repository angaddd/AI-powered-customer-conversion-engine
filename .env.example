DJANGO_SECRET_KEY=dev-only-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

DB_ENGINE=django.db.backends.mysql
DB_NAME=ai_crm
DB_USER=ai_crm
DB_PASSWORD=ai_crm
DB_HOST=127.0.0.1
DB_PORT=3306

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
REDIS_CACHE_URL=redis://localhost:6379/2

# Keep this off locally so tracking requests are written to the database before
# the browser gets a success response. Turn it on only when a Celery worker is running.
TRACK_EVENTS_ASYNC=0
